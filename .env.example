# Weather Agents - Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Key (for GPT-4o, GPT-4.1, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (for Claude Sonnet, Opus, Haiku)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek API Key (optional)
# DEEPSEEK_API_KEY=your-deepseek-key-here

# GitHub Token (for MCP GitHub server)
# GITHUB_TOKEN=ghp_your-github-token-here

# Web dashboard auth token (optional, for production)
# WA_API_TOKEN=your-secret-token-here
